<resources xmlns:tools="http://schemas.android.com/tools">
  <!-- Base application theme. -->
  <style name="Base.AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
    <item name="alertDialogTheme">@style/HavenDialogTheme</item>
    <item name="android:alertDialogTheme">@style/HavenDialogTheme</item>
    <item name="android:statusBarColor">@android:color/transparent</item>
    <item name="android:navigationBarColor">@android:color/transparent</item>
    <item name="android:windowDrawsSystemBarBackgrounds">true</item>
  </style>

  <style name="AppTheme" parent="Base.AppTheme" />

  <!-- 浅色模式弹窗（Claude 配色） -->
  <style name="HavenDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
    <item name="android:windowBackground">@drawable/dialog_bg</item>
    <item name="android:textColor">#2D2B28</item>
    <item name="android:textColorPrimary">#2D2B28</item>
    <item name="android:textColorSecondary">#6B6560</item>
    <item name="android:textColorHint">#4D6B6560</item>
    <item name="android:editTextColor">#2D2B28</item>
    <item name="colorPrimary">#C49A6C</item>
    <item name="colorOnPrimary">#FFFFFF</item>
    <item name="colorOnSurface">#2D2B28</item>
    <item name="colorOnSurfaceVariant">#6B6560</item>
    <item name="colorSurface">#FDFCFA</item>
    <item name="colorSurfaceVariant">#F8F7F4</item>
    <item name="android:textColorAlertDialogListItem">#2D2B28</item>
    <item name="android:listPreferredItemHeightSmall">52dp</item>
    <item name="buttonBarPositiveButtonStyle">@style/HavenDialogButton</item>
    <item name="buttonBarNegativeButtonStyle">@style/HavenDialogButtonNeg</item>
  </style>

  <style name="HavenDialogButton" parent="Widget.Material3.Button.TextButton.Dialog">
    <item name="android:textColor">#C49A6C</item>
    <item name="android:textSize">14sp</item>
    <item name="android:paddingStart">20dp</item>
    <item name="android:paddingEnd">20dp</item>
  </style>

  <style name="HavenDialogButtonNeg" parent="Widget.Material3.Button.TextButton.Dialog">
    <item name="android:textColor">#8A7E74</item>
    <item name="android:textSize">14sp</item>
    <item name="android:paddingStart">20dp</item>
    <item name="android:paddingEnd">20dp</item>
  </style>
</resources>