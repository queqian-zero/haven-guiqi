<resources xmlns:tools="http://schemas.android.com/tools">
  <style name="Base.AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
    <item name="alertDialogTheme">@style/HavenDialogTheme</item>
    <item name="android:alertDialogTheme">@style/HavenDialogTheme</item>
  </style>

  <style name="AppTheme" parent="Base.AppTheme" />

  <!-- 深色模式弹窗 -->
  <style name="HavenDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
    <item name="android:windowBackground">@drawable/dialog_bg</item>
    <item name="android:textColor">#D9FFFFFF</item>
    <item name="android:textColorPrimary">#D9FFFFFF</item>
    <item name="android:textColorSecondary">#80FFFFFF</item>
    <item name="android:textColorHint">#4DFFFFFF</item>
    <item name="android:editTextColor">#D9FFFFFF</item>
    <item name="colorPrimary">#B3A0FF</item>
    <item name="colorOnPrimary">#FFFFFF</item>
    <item name="colorOnSurface">#D9FFFFFF</item>
    <item name="colorOnSurfaceVariant">#B3FFFFFF</item>
    <item name="colorSurface">#0D1B2A</item>
    <item name="colorSurfaceVariant">#1A2535</item>
    <item name="android:textColorAlertDialogListItem">#D9FFFFFF</item>
    <item name="android:listPreferredItemHeightSmall">48dp</item>
  </style>
</resources>