<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/chat_bg"
    android:orientation="vertical">

    <!-- ===== 顶部栏：返回 + 名字 + 菜单 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- 返回按钮 -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="←"
            android:textColor="#59FFFFFF"
            android:textSize="18sp" />

        <!-- 中间：名字 + 状态 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFriendName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="星河"
                android:textColor="#D9FFFFFF"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="在线"
                android:textColor="#4DB3A0FF"
                android:textSize="9sp"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- 右侧菜单按钮 -->
        <TextView
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="⋮"
            android:textColor="#33FFFFFF"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#08FFFFFF" />

    <!-- 断网/状态提示条 -->
    <TextView
        android:id="@+id/connectionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#33FF6B6B"
        android:gravity="center"
        android:paddingVertical="6dp"
        android:text="网络连接失败，请检查网络"
        android:textColor="#CCFF6B6B"
        android:textSize="11sp"
        android:visibility="gone" />

    <!-- ===== 消息区域 ===== -->
    <ScrollView
        android:id="@+id/scrollMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/messagesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />
    </ScrollView>

    <!-- ===== 图片预览区 ===== -->
    <LinearLayout
        android:id="@+id/imagePreviewContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone" />

    <!-- ===== 引用预览区 ===== -->
    <LinearLayout
        android:id="@+id/quotePreviewContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone" />

    <!-- ===== 底部输入栏（普通模式） ===== -->
    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:background="#08FFFFFF">

        <!-- 加号按钮 -->
        <TextView
            android:id="@+id/btnPlus"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="＋"
            android:textColor="#26FFFFFF"
            android:textSize="20sp" />

        <!-- 输入框 -->
        <EditText
            android:id="@+id/inputMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:minHeight="38dp"
            android:maxLines="4"
            android:background="@drawable/chat_input_bg"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:hint="说点什么..."
            android:textColor="#B3FFFFFF"
            android:textColorHint="#26FFFFFF"
            android:textSize="14sp"
            android:inputType="textMultiLine"
            android:imeOptions="actionNone" />

        <!-- 展开按钮 -->
        <TextView
            android:id="@+id/btnExpand"
            android:layout_width="28dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="↕"
            android:textColor="#26FFFFFF"
            android:textSize="16sp" />

        <!-- 发送按钮 -->
        <TextView
            android:id="@+id/btnSend"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="➤"
            android:textColor="#4DB3A0FF"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- ===== 展开模式（半屏大输入框） ===== -->
    <LinearLayout
        android:id="@+id/expandedInputPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#0D1B2A"
        android:visibility="gone">

        <!-- 展开模式顶栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:background="#08FFFFFF">

            <TextView
                android:id="@+id/btnCollapse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↕ 收起"
                android:textColor="#4DB3A0FF"
                android:textSize="13sp"
                android:paddingHorizontal="4dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/btnExpandSend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="发送 ➤"
                android:textColor="#4DB3A0FF"
                android:textSize="13sp"
                android:paddingHorizontal="4dp" />
        </LinearLayout>

        <!-- 大输入框 -->
        <EditText
            android:id="@+id/expandedInput"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:hint="展开模式：回车就是换行，不会发送\n写完点右上角「发送」"
            android:textColor="#B3FFFFFF"
            android:textColorHint="#26FFFFFF"
            android:textSize="14sp"
            android:inputType="textMultiLine"
            android:gravity="top"
            android:scrollbars="vertical" />
    </LinearLayout>

</LinearLayout>