<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/chat_bg"
    android:orientation="vertical">

    <!-- ===== 内容区域（四个标签页叠在一起，切换显示） ===== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- 来信页 -->
        <LinearLayout
            android:id="@+id/tabMessages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="来信"
                    android:textColor="@color/haven_text_primary"
                    android:textSize="22sp"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/btnAddFromMessages"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="＋"
                    android:textColor="@color/haven_accent"
                    android:textSize="20sp" />
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none"
                android:paddingHorizontal="14dp">

                <LinearLayout
                    android:id="@+id/messagesList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="16dp" />
            </ScrollView>
        </LinearLayout>

        <!-- 好友页 -->
        <LinearLayout
            android:id="@+id/tabFriends"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp"
                android:text="好友"
                android:textColor="@color/haven_text_primary"
                android:textSize="22sp"
                android:letterSpacing="0.15" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none"
                android:paddingHorizontal="14dp">

                <LinearLayout
                    android:id="@+id/friendsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="16dp" />
            </ScrollView>
        </LinearLayout>

        <!-- 足迹页 -->
        <LinearLayout
            android:id="@+id/tabFootprints"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="足迹"
                    android:textColor="@color/haven_text_primary"
                    android:textSize="22sp"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/btnPostFootprint"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="✎"
                    android:textColor="@color/haven_accent"
                    android:textSize="18sp" />
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none"
                android:paddingHorizontal="14dp">

                <LinearLayout
                    android:id="@+id/footprintsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="24dp" />
            </ScrollView>
        </LinearLayout>

        <!-- 我的页 -->
        <LinearLayout
            android:id="@+id/tabProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp"
                android:text="我的"
                android:textColor="@color/haven_text_primary"
                android:textSize="22sp"
                android:letterSpacing="0.15" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none"
                android:paddingHorizontal="14dp">

                <LinearLayout
                    android:id="@+id/profileContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="24dp" />
            </ScrollView>
        </LinearLayout>

    </FrameLayout>

    <!-- ===== 底部标签栏 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/haven_divider"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/btnTabMessages"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/iconTabMessages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✉"
                android:textSize="18sp"
                android:textColor="@color/haven_accent" />

            <TextView
                android:id="@+id/labelTabMessages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="来信"
                android:textSize="9sp"
                android:textColor="@color/haven_accent"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabFriends"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/iconTabFriends"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♡"
                android:textSize="18sp"
                android:textColor="@color/haven_text_hint" />

            <TextView
                android:id="@+id/labelTabFriends"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="好友"
                android:textSize="9sp"
                android:textColor="@color/haven_text_hint"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabFootprints"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/iconTabFootprints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☆"
                android:textSize="18sp"
                android:textColor="@color/haven_text_hint" />

            <TextView
                android:id="@+id/labelTabFootprints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="足迹"
                android:textSize="9sp"
                android:textColor="@color/haven_text_hint"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnTabProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/iconTabProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○"
                android:textSize="18sp"
                android:textColor="@color/haven_text_hint" />

            <TextView
                android:id="@+id/labelTabProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="我的"
                android:textSize="9sp"
                android:textColor="@color/haven_text_hint"
                android:layout_marginTop="1dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>